@* Views/Home/Index.cshtml *@
@{
    ViewData["Title"] = "استوديو التصميم - نظام الشهايد";
}

<div class="dashboard-wrapper animate-fade-in" dir="rtl">
    <form asp-action="GenerateCertificates" asp-controller="Home" method="post" enctype="multipart/form-data" class="d-flex w-100">
        <!-- Sidebar Settings: لوحة التحكم الجانبية -->
        <aside class="settings-sidebar">
            <div class="sidebar-header mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h4 class="fw-bold text-main mb-1">استوديو التصميم</h4>
                        <p class="text-muted small mb-0">تحكم كامل في كل تفاصيل الشهادة</p>
                    </div>
                </div>
            </div>

            <div class="accordion custom-accordion" id="settingsAccordion">
                <!-- 1. Media & Source: رفع القالب والبيانات -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFiles">
                            <i class="fa-solid fa-photo-film me-2 text-primary"></i> 1. الوسائط والبيانات
                        </button>
                    </h2>
                    <div id="collapseFiles" class="accordion-collapse collapse show" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <div class="mb-4">
                                <label class="form-label-premium">قالب الشهادة (صورة)</label>
                                <div class="file-upload-wrapper border rounded-4 p-4 text-center transition-all" onclick="document.getElementById('TemplateFile').click()" style="cursor: pointer; background: var(--bg-app);">
                                    <i class="fa-solid fa-cloud-arrow-up fs-1 mb-2 text-primary opacity-50"></i>
                                    <p class="small mb-0 text-muted">اسحب القالب هنا أو انقر للاختيار</p>
                                    <input type="file" id="TemplateFile" name="TemplateFile" class="d-none" accept="image/*" required onchange="previewImage(event)" />
                                </div>
                            </div>

                            <div class="card border-0 bg-app p-3 rounded-4 mb-3">
                                <label class="form-label-premium text-primary d-flex align-items-center mb-3">
                                    <i class="fa-solid fa-users-gear me-2"></i> مصدر البيانات
                                </label>
                                
                                <div class="row g-2 mb-3">
                                    <div class="col-12">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass small text-muted"></i></span>
                                            <input type="text" id="filterSearch" class="form-control border-start-0 ps-0" placeholder="بحث بالاسم..." onkeyup="fetchEmployees()">
                                        </div>
                                    </div>
                                    <div class="col-12">
                                        <select id="filterDepartment" class="form-select form-select-sm" onchange="fetchEmployees()">
                                            <option value="">كل الأقسام</option>
                                            <option value="الإدارة العليا">الإدارة العليا</option>
                                            <option value="تقنية المعلومات">تقنية المعلومات</option>
                                            <option value="الموارد البشرية">الموارد البشرية</option>
                                            <option value="التسويق">التسويق</option>
                                            <option value="العمليات">العمليات</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="table-responsive rounded-3 border bg-white" style="max-height: 180px; overflow-y: auto;">
                                    <table class="table table-sm table-hover mb-0" style="font-size: 0.75rem;">
                                        <thead class="bg-light sticky-top">
                                            <tr>
                                                 <th width="30"><input type="checkbox" id="selectAllEmployees" onchange="toggleAllEmployees(this)" class="form-check-input"></th>
                                                 <th>الاسم</th>
                                                 <th>البريد/الجوال</th>
                                                 <th>إجراء</th>
                                             </tr>
                                        </thead>
                                        <tbody id="employeesTableBody">
                                            <tr><td colspan="3" class="text-center py-3 text-muted">جاري التحميل...</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                                <input type="hidden" name="SelectedEmployeeIds" id="SelectedEmployeeIds" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Elements & Layers: التحكم في الطبقات (الاسم، السجل، التاريخ) -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseText">
                            <i class="fa-solid fa-layer-group me-2 text-primary"></i> 2. العناصر والطبقات
                        </button>
                    </h2>
                    <div id="collapseText" class="accordion-collapse collapse" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <!-- طبقة الاسم -->
                            <div class="layer-card p-3 border rounded-4 mb-3 bg-app">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-user-tag me-1"></i> طبقة الاسم</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked disabled></div>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-12">
                                        <label class="small text-muted mb-1">الخط</label>
                                        <select name="NameFontFamily" id="NameFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Tajawal">Tajawal (Default)</option>
                                            <option value="Cairo">Cairo</option>
                                            <option value="Arial">Arial</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted mb-1">الحجم</label>
                                        <input type="number" name="NameFontSize" id="NameFontSize" class="form-control form-control-sm" value="48" oninput="updateDraggableDesign()" />
                                    </div>
                                    <div class="col-6">
                                        <label class="small text-muted mb-1">اللون</label>
                                        <input type="color" name="NameFontColor" id="NameFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#000000" oninput="updateDraggableDesign()" />
                                    </div>
                                    <div class="col-12">
                                        <label class="small text-muted mb-1">المحاذاة</label>
                                        <select name="NameTextAlign" id="NameTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Center">توسيط</option>
                                            <option value="Right">يمين</option>
                                            <option value="Left">يسار</option>
                                        </select>
                                    </div>
                                </div>
                                <input type="hidden" id="NameX" name="NameX" value="500" />
                                <input type="hidden" id="NameY" name="NameY" value="400" />
                            </div>

                            <!-- طبقة السجل المدني -->
                            <div class="layer-card p-3 border rounded-4 mb-3 bg-app">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-id-card me-1"></i> طبقة السجل</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleCivil" checked onchange="toggleLayer('previewCivil', this)"></div>
                                </div>
                                <div class="row g-2 mb-2 layer-controls">
                                    <div class="col-12">
                                        <select name="CivilIdFontFamily" id="CivilIdFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Tajawal">Tajawal</option>
                                            <option value="Arial">Arial</option>
                                        </select>
                                    </div>
                                    <div class="col-6"><input type="number" name="CivilIdFontSize" id="CivilIdFontSize" class="form-control form-control-sm" value="32" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><input type="color" name="CivilIdFontColor" id="CivilIdFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#333333" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-12">
                                        <select name="CivilIdTextAlign" id="CivilIdTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Center">توسيط</option>
                                            <option value="Right">يمين</option>
                                            <option value="Left">يسار</option>
                                        </select>
                                    </div>
                                </div>
                                <input type="hidden" id="CivilIdX" name="CivilIdX" value="500" />
                                <input type="hidden" id="CivilIdY" name="CivilIdY" value="500" />
                            </div>

                            <!-- طبقة التاريخ -->
                            <div class="layer-card p-3 border rounded-4 mb-3 bg-app">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-calendar-day me-1"></i> طبقة التاريخ</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleDate" checked onchange="toggleLayer('previewDate', this)"></div>
                                </div>
                                <div class="layer-controls">
                                    <input type="text" name="DateText" id="DateText" class="form-control form-control-sm mb-2" value="@DateTime.Now.ToString("yyyy/MM/dd")" oninput="updateText('previewDate', this.value)" />
                                    <div class="row g-2 mb-2">
                                        <div class="col-12">
                                            <select name="DateFontFamily" id="DateFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                                <option value="Tajawal">Tajawal</option>
                                                <option value="Arial">Arial</option>
                                            </select>
                                        </div>
                                        <div class="col-6"><input type="number" name="DateFontSize" id="DateFontSize" class="form-control form-control-sm" value="28" oninput="updateDraggableDesign()" /></div>
                                        <div class="col-6"><input type="color" name="DateFontColor" id="DateFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#555555" oninput="updateDraggableDesign()" /></div>
                                        <div class="col-12">
                                            <select name="DateTextAlign" id="DateTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                                <option value="Center">توسيط</option>
                                                <option value="Right">يمين</option>
                                                <option value="Left">يسار</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" id="DateX" name="DateX" value="800" />
                                <input type="hidden" id="DateY" name="DateY" value="800" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Finalize: خيارات التصدير والإرسال -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExport">
                            <i class="fa-solid fa-file-export me-2 text-primary"></i> 3. التصدير والتحميل
                        </button>
                    </h2>
                    <div id="collapseExport" class="accordion-collapse collapse" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <label class="form-label-premium">تنسيق المخرجات</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="ExportType" id="png" value="png" checked>
                                <label class="btn btn-outline-primary py-2" for="png">PNG</label>
                                <input type="radio" class="btn-check" name="ExportType" id="jpg" value="jpg">
                                <label class="btn btn-outline-primary py-2" for="jpg">JPG</label>
                                <input type="radio" class="btn-check" name="ExportType" id="pdf" value="pdf">
                                <label class="btn btn-outline-primary py-2" for="pdf">PDF</label>
                            </div>

                            <div class="mt-4 border-top pt-3">
                                <label class="form-label-premium mb-3 d-block"><i class="fa-solid fa-paper-plane me-1"></i> خيارات الإرسال</label>
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="SendEmail" name="SendEmail" value="true">
                                    <label class="form-check-label small" for="SendEmail">إرسال عبر البريد الإلكتروني</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="SendWhatsApp" name="SendWhatsApp" value="true">
                                    <label class="form-check-label small" for="SendWhatsApp">إرسال عبر الواتساب</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-4 border-top">
                <button type="submit" class="btn btn-premium btn-premium-primary w-100 py-3 shadow-lg animate-pulse-hover">
                    <i class="fa-solid fa-wand-magic-sparkles me-2"></i> توليد الشهايد الآن
                </button>
            </div>
        </aside>

        <!-- Main Workspace: منطقة العمل والمعاينة -->
        <main class="workspace-area">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="animate-slide-in">
                    <h4 class="fw-bold text-main mb-0">لوحة التصميم الذكية</h4>
                    <p class="text-muted small">حدد مواقع العناصر بدقة عن طريق السحب</p>
                </div>
            </div>

            <div class="preview-container-wrapper shadow-inner">
                <!-- رسالة البدء عند عدم وجود صورة -->
                <div id="noImageOverlay" class="text-center p-5 animate-fade-in">
                    <div class="mb-4 studio-icon">
                        <i class="fa-solid fa-wand-magic-sparkles text-primary opacity-25" style="font-size: 80px;"></i>
                    </div>
                    <h5 class="text-main fw-bold">ارفع قالبك للبدء</h5>
                    <p class="text-muted small mx-auto" style="max-width: 300px;">بمجرد رفع صورة القالب، ستتمكن من التحكم في جميع العناصر والبيانات مباشرة</p>
                </div>

                <!-- حاوية المعاينة والعناصر القابلة للسحب -->
                <div id="imageContainer" style="position: relative; display: none;" class="animate-scale-in">
                    <img id="imagePreview" src="#" alt="معاينة" class="fit-image shadow-xl rounded-2" />
                    
                    <div id="previewName" class="draggable-text-premium" data-targetx="NameX" data-targety="NameY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">اسم المتدرب</div>
                    </div>
                    <div id="previewCivil" class="draggable-text-premium" data-targetx="CivilIdX" data-targety="CivilIdY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">1000000000</div>
                    </div>
                    <div id="previewDate" class="draggable-text-premium" data-targetx="DateX" data-targety="DateY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">@DateTime.Now.ToString("yyyy/MM/dd")</div>
                    </div>
                </div>
            </div>
        </main>
    </form>
</div>

@section Scripts {
    <script>
        // منطق معاينة الصورة المرفوعة
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('imagePreview');
                output.src = reader.result;
                document.getElementById('imageContainer').style.display = 'inline-block';
                document.getElementById('noImageOverlay').style.display = 'none';

                output.onload = function() {
                    document.querySelectorAll('.draggable-text-premium').forEach(function(el) {
                        updateOverlayPosFromInputs(el);
                    });
                    updateDraggableDesign();
                };
            }
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        // منطق السحب والإفلات (Drag and Drop)
        let activeEl = null;
        let isDragging = false;
        let startX, startY, initialLeft, initialTop;

        document.querySelectorAll('.draggable-text-premium').forEach(item => {
            item.addEventListener('mousedown', function(e) {
                isDragging = true;
                activeEl = item;
                startX = e.clientX;
                startY = e.clientY;
                initialLeft = parseFloat(getComputedStyle(item).left) || 0;
                initialTop = parseFloat(getComputedStyle(item).top) || 0;
                e.preventDefault();
            });
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging || !activeEl) return;
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            activeEl.style.left = (initialLeft + dx) + 'px';
            activeEl.style.top = (initialTop + dy) + 'px';
        });

        document.addEventListener('mouseup', function() {
            if (isDragging && activeEl) {
                var img = document.getElementById('imagePreview');
                var rect = img.getBoundingClientRect();
                var currentLeft = parseFloat(getComputedStyle(activeEl).left) || 0;
                var currentTop = parseFloat(getComputedStyle(activeEl).top) || 0;
                var scaleX = img.naturalWidth / rect.width;
                var scaleY = img.naturalHeight / rect.height;

                // تحديث القيم المخفية لإرسالها للخادم
                document.getElementById(activeEl.getAttribute("data-targetx")).value = Math.round(currentLeft * scaleX);
                document.getElementById(activeEl.getAttribute("data-targety")).value = Math.round(currentTop * scaleY);
            }
            isDragging = false;
            activeEl = null;
        });

        // تحديث التصميم المباشر (الخط، الحجم، اللون)
        function updateDraggableDesign() {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth || 1;

            let configs = [
                { id: 'previewName', prefix: 'Name' },
                { id: 'previewCivil', prefix: 'CivilId' },
                { id: 'previewDate', prefix: 'Date' }
            ];

            configs.forEach(conf => {
                let textEl = document.getElementById(conf.id);
                if (textEl) {
                    let content = textEl.querySelector('.text-content');
                    content.style.color = document.getElementById(conf.prefix + 'FontColor')?.value || '#000';
                    content.style.fontFamily = document.getElementById(conf.prefix + 'FontFamily')?.value || 'Tajawal';
                    let rawSize = document.getElementById(conf.prefix + 'FontSize')?.value || 32;
                    content.style.fontSize = (rawSize * scaleX) + 'px';
                }
            });
        }

        // جلب الموظفين من قاعدة البيانات
        async function fetchEmployees() {
            let search = document.getElementById('filterSearch').value;
            let department = document.getElementById('filterDepartment').value;
            let params = new URLSearchParams({ search: search, department: department });
            try {
                let response = await fetch('/Home/GetEmployees?' + params.toString());
                let data = await response.json();
                renderEmployees(data);
            } catch(e) { console.error(e); }
        }

        function renderEmployees(employees) {
            let tbody = document.getElementById('employeesTableBody');
            tbody.innerHTML = '';
            employees.forEach(emp => {
                let tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><input type="checkbox" class="emp-checkbox form-check-input" value="${emp.id}" onchange="updateSelectedIds()"></td>
                    <td><div class="fw-bold">${emp.name}</div></td>
                    <td><div class="small text-muted">${emp.email || emp.phone || '-'}</div></td>
                    <td><i class="fa-solid fa-circle-check text-success"></i></td>
                `;
                tbody.appendChild(tr);
            });
        }

        function updateSelectedIds() {
            let selected = Array.from(document.querySelectorAll('.emp-checkbox:checked')).map(cb => cb.value);
            document.getElementById('SelectedEmployeeIds').value = selected.join(',');
        }

        // استدعاء أولي للموظفين
        fetchEmployees();
    </script>
}
